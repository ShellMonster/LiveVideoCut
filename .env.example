# VLM Configuration (Qwen-VL-Plus)
VLM_API_KEY=your-api-key-here
VLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VLM_MODEL=qwen-vl-plus

# HuggingFace Mirror (China)
HF_ENDPOINT=https://hf-mirror.com

# Redis
REDIS_URL=redis://redis:6379/0

# Volcengine ASR Configuration
VOLCENGINE_ASR_API_KEY=your-volcengine-api-key

# Volcengine TOS (Object Storage) for ASR
TOS_AK=your-tos-access-key
TOS_SK=your-tos-secret-key
TOS_BUCKET=mp3-srt
TOS_REGION=cn-beijing
TOS_ENDPOINT=tos-cn-beijing.volces.com

# LLM Text Analysis
LLM_API_KEY=your-llm-api-key
LLM_API_BASE=https://your-api-base/v1
LLM_MODEL=your-model-name
LLM_TYPE=openai

# AI Commerce Gemini Product Recognition
COMMERCE_GEMINI_API_KEY=your-gemini-api-key
COMMERCE_GEMINI_API_BASE=https://generativelanguage.googleapis.com
COMMERCE_GEMINI_MODEL=gemini-3-flash-preview

# AI Commerce OpenAI Image
COMMERCE_IMAGE_API_KEY=your-openai-compatible-image-key
COMMERCE_IMAGE_API_BASE=https://your-api-base/v1
COMMERCE_IMAGE_MODEL=gpt-image-2
COMMERCE_IMAGE_SIZE=2K
COMMERCE_IMAGE_QUALITY=auto

# Upload limits
MAX_UPLOAD_SIZE_GB=20

# China Docker build mirrors
DOCKER_REGISTRY=
APT_MIRROR=
PYPI_INDEX_URL=
NPM_REGISTRY=
