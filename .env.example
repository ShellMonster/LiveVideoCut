# VLM Configuration (Qwen-VL-Plus)
VLM_API_KEY=your-api-key-here
VLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VLM_MODEL=qwen-vl-plus

# FunASR Configuration
FUNASR_URL=http://funasr:10095

# Local ASR Configuration (faster-whisper)
FASTER_WHISPER_MODEL=small
FASTER_WHISPER_DEVICE=cpu
FASTER_WHISPER_COMPUTE_TYPE=int8
HF_ENDPOINT=https://hf-mirror.com

# Redis
REDIS_URL=redis://redis:6379/0

# Volcengine ASR Configuration
VOLCENGINE_ASR_API_KEY=your-volcengine-api-key

# Volcengine TOS (Object Storage) for ASR
TOS_AK=your-tos-access-key
TOS_SK=your-tos-secret-key
TOS_BUCKET=mp3-srt
TOS_REGION=cn-beijing
TOS_ENDPOINT=tos-cn-beijing.volces.com

# LLM Text Analysis
LLM_API_KEY=your-llm-api-key
LLM_API_BASE=https://your-api-base/v1
LLM_MODEL=your-model-name
LLM_TYPE=openai

# Upload limits
MAX_UPLOAD_SIZE_GB=20

# China Docker build mirrors
DOCKER_REGISTRY=
APT_MIRROR=
PYPI_INDEX_URL=
NPM_REGISTRY=
